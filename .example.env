# Optional API key. Leave empty to disable authentication.
# When set, clients must send: X-API-Key: <value>
IDREF_API_KEY=

# Public IdRef / Qualinka endpoints
FIND_RA_ENDPOINT=https://qualinka.idref.fr/data/find-ra-idref/api/v2/debug/req
ATTRRA_ENDPOINT=https://qualinka.idref.fr/data/attrra/api/v2/req
REFERENCES_ENDPOINT=https://www.idref.fr/services/references/{ppn}.json
IDREF_USER_AGENT=humatheque-idref-qualinka-api/0.1

# Request behavior
IDREF_HTTP_TIMEOUT=20.0
IDREF_MAX_RETRIES=2
IDREF_BACKOFF_BASE=1.0

# Alignment defaults
IDREF_MAX_CANDIDATES=20
IDREF_MAX_DOCS_PER_ROLE=20
IDREF_REFERENCE_TOP_K=3
IDREF_ACCEPT_THRESHOLD=0.65
IDREF_MARGIN_THRESHOLD=0.08

# Optional sentence-transformers model. Leave empty for lexical scoring.
# Example: sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
IDREF_EMBEDDING_MODEL=
